<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F3F4F6">

        <!-- ══ HEADER (top) ══ -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:background="#1D4ED8"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="4dp"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Tên app -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Rem2"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingEnd="8dp" />

            <!-- URL input -->
            <EditText
                android:id="@+id/etUrl"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/url_bar_bg"
                android:textColor="#FFFFFF"
                android:textColorHint="#AADDFF"
                android:hint="Nhập URL hoặc tìm kiếm..."
                android:textSize="12sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:textCursorDrawable="@null"
                android:layout_marginEnd="6dp" />

            <!-- Tab switcher -->
            <TextView
                android:id="@+id/btnTabCount"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/tab_btn_bg"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="2dp" />

            <!-- Clipboard/Log toggle -->
            <ImageButton
                android:id="@+id/btnToggleLog"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_paste"
                android:tint="#FFFFFF"
                android:contentDescription="Toggle log" />

            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_refresh"
                android:tint="#FFFFFF"
                android:contentDescription="Tai lai trang" />

            <!-- Ẩn: binding compat cho btnBack và btnMenu — không hiển thị -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ══ PROGRESS BAR (below header) ══ -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:visibility="gone"
            android:progressTint="#60A5FA"
            android:progressBackgroundTint="#1D4ED8"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ LOG + XÁC THỰC PANEL ══ -->
        <LinearLayout
            android:id="@+id/logPanel"
            android:layout_width="0dp"
            android:layout_height="300dp"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#FFFFFF"
            android:elevation="6dp"
            app:layout_constraintTop_toBottomOf="@id/progressBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Tab row: Log | Xác thực -->
            <LinearLayout
                android:id="@+id/panelTabRow"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="#F3F4F6"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tabLog"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="📋 Log"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#1D4ED8"
                    android:textStyle="bold"
                    android:background="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tabVerify"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="📬 Mail.tm"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#6B7280"
                    android:background="#F3F4F6"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Nút tạo tài khoản -->
            <LinearLayout
                android:id="@+id/ctaRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:background="#FFFFFF">

                <Button
                    android:id="@+id/btnCreateAccount"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="🔄 Tao tai khoan moi"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1D4ED8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- Log scroll -->
            <ScrollView
                android:id="@+id/logScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="#111827"
                    android:lineSpacingExtra="2dp"
                    android:textIsSelectable="true" />

            </ScrollView>

            <!-- Verify mini WebView -->
            <WebView
                android:id="@+id/verifyWebView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ══ TAB 1 — Replit WebView ══ -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/logPanel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <WebView
                android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- ══ TAB 2 — WebView phụ ══ -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="invisible"
            app:layout_constraintTop_toBottomOf="@id/logPanel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <WebView
                android:id="@+id/webView2"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
