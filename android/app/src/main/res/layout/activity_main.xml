<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <WebView
        android:id="@+id/mainWebView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/mailPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/autoRegisterOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ProgressBar
            android:id="@+id/autoRegisterProgress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:indeterminateTint="#4FC3F7"/>
        <TextView
            android:id="@+id/tvAutoStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Initializing..."
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"/>
        <Button
            android:id="@+id/btnSkipAutoReg"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Skip / Do manually"
            android:textColor="#90CAF9"
            android:textSize="13sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/mailPanel"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:orientation="vertical"
        android:background="#0D1117"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="4dp"
            android:background="#1565C0">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mail_panel_title"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvMailStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Not connected"
                android:textColor="#90CAF9"
                android:textSize="11sp"
                android:ellipsize="end"
                android:maxLines="1"/>
            <Button
                android:id="@+id/btnAutoSetup"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textColor="#4FC3F7"
                android:textSize="12sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"/>
            <Button
                android:id="@+id/btnRefresh"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="&#x21BB;"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"/>
            <Button
                android:id="@+id/btnClose"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="&#x2715;"
                android:textColor="#AAAAAA"
                android:textSize="16sp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="#0D1117">
            <Button
                android:id="@+id/tabMailList"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Inbox"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="#1565C0"/>
            <Button
                android:id="@+id/tabVerify"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Verify Browser"
                android:textColor="#90CAF9"
                android:textSize="13sp"
                android:background="@null"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:id="@+id/mailListContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0D1117">
                <LinearLayout
                    android:id="@+id/mailList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp"/>
            </ScrollView>

            <WebView
                android:id="@+id/verifyWebView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"/>

        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/sym_action_email"
        app:backgroundTint="#1976D2"
        app:layout_constraintBottom_toTopOf="@+id/mailPanel"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
