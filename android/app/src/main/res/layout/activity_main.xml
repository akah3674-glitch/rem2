<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ── Tab bar: scrollable tabs ────────────────────────────────── -->
    <HorizontalScrollView
        android:id="@+id/tabScrollView"
        android:layout_width="0dp"
        android:layout_height="38dp"
        android:background="#F5F5F5"
        android:scrollbars="none"
        android:fillViewport="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tabActions">

        <LinearLayout
            android:id="@+id/tabBar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>
    </HorizontalScrollView>

    <!-- Tab quick actions: Reload + New Tab -->
    <LinearLayout
        android:id="@+id/tabActions"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingEnd="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnReload"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="↻"
            android:textSize="20sp"
            android:gravity="center"
            android:textColor="#1565C0"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tải lại"/>

        <TextView
            android:id="@+id/btnNewTab"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="＋"
            android:textSize="18sp"
            android:gravity="center"
            android:textColor="#1565C0"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tab mới"/>
    </LinearLayout>

    <!-- Divider below tab bar -->
    <View
        android:id="@+id/tabDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@+id/tabScrollView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── WebView container: always full height (panel overlays it) ── -->
    <FrameLayout
        android:id="@+id/webContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/tabDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Mail Panel: floating overlay from bottom (55% height) ────── -->
    <LinearLayout
        android:id="@+id/mailPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.56"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0">

        <!-- Panel header -->
        <LinearLayout
            android:id="@+id/panelHeader"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#F5F5F5"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- Drag handle indicator -->
            <View
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_marginStart="8dp"
                android:background="#DDDDDD"
                android:layout_gravity="center_vertical"/>
            <!-- Desktop mode -->
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnDesktop"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_always_landscape_portrait"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#555555"
                android:alpha="0.5"/>

            <!-- New mail (+) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRefresh"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="+"
                android:textColor="#1565C0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"/>
            </LinearLayout>

        <!-- Section tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="#F5F5F5">

            <TextView
                android:id="@+id/tabAccounts"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="👤 Tài khoản"
                android:textColor="#90CAF9"
                android:textSize="12sp"
                android:gravity="center"
                android:background="#1565C0"/>

            <TextView
                android:id="@+id/tabMailList"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📧 Xác thực"
                android:textColor="#90CAF9"
                android:textSize="12sp"
                android:gravity="center"
                android:background="@android:color/transparent"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"/>

        <!-- Content area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- ── Accounts section ── -->
            <LinearLayout
                android:id="@+id/accountsContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/accountList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </ScrollView>

                <TextView
                    android:id="@+id/tvAccountsEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Chưa có tài khoản\nĐăng nhập Replit để lưu tự động"
                    android:textColor="#777777"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- ── Verify / Inbox section ── -->
            <LinearLayout
                android:id="@+id/verifyContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvMailStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đang khởi tạo..."
                    android:textColor="#555555"
                    android:textSize="11sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="2dp"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <!-- Mail list + verify WebView stacked -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <ScrollView
                        android:id="@+id/mailListScroll"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:id="@+id/mailList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>
                    </ScrollView>

                    <!-- Verify WebView (shown when link loaded) -->
                    <WebView
                        android:id="@+id/verifyWebView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"/>
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#F5F5F5"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvBottomStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#777777"
                android:textSize="10sp"
                android:ellipsize="end"
                android:maxLines="1"/>

            <ProgressBar
                android:id="@+id/pbMail"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:indeterminateTint="#1565C0"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
