<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ── Tab bar ──────────────────────────────────────────────────────── -->
    <HorizontalScrollView
        android:id="@+id/tabScrollView"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:background="#F0F0F0"
        android:scrollbars="none"
        android:fillViewport="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tabActions">

        <LinearLayout
            android:id="@+id/tabBar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>
    </HorizontalScrollView>

    <!-- Reload + New Tab actions -->
    <LinearLayout
        android:id="@+id/tabActions"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F0F0F0"
        android:paddingEnd="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnReload"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="↻"
            android:textSize="19sp"
            android:gravity="center"
            android:textColor="#1565C0"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tải lại"/>

        <TextView
            android:id="@+id/btnNewTab"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="＋"
            android:textSize="17sp"
            android:gravity="center"
            android:textColor="#1565C0"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tab mới"/>
    </LinearLayout>

    <!-- Divider below tab bar -->
    <View
        android:id="@+id/tabDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        app:layout_constraintTop_toBottomOf="@+id/tabScrollView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── WebView container ─────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/webContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/tabDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Mail Panel: floating overlay from bottom (58% height) ─────────── -->
    <LinearLayout
        android:id="@+id/mailPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.60"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0">

        <!-- ── Panel header ── -->
        <LinearLayout
            android:id="@+id/panelHeader"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:paddingStart="10dp"
            android:paddingEnd="4dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvPanelTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📨 Rem2"
                android:textColor="#1565C0"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <!-- Search input -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:visibility="gone"
                android:background="@drawable/search_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="#1A237E"
                android:textColorHint="#9FA8DA"
                android:textSize="12sp"
                android:hint="Tìm kiếm hoặc nhập URL..."
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:maxLines="1"
                android:singleLine="true"/>

            <!-- Search icon -->
            <TextView
                android:id="@+id/btnToggleSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔍"
                android:textSize="15sp"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Tìm kiếm"/>

            <!-- Desktop mode -->
            <TextView
                android:id="@+id/btnDesktop"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🖥"
                android:textSize="15sp"
                android:gravity="center"
                android:textColor="#888888"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Máy tính"/>

            <!-- New mail (+) -->
            <TextView
                android:id="@+id/btnNewMail"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="✉+"
                android:textSize="14sp"
                android:gravity="center"
                android:textColor="#1565C0"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Tạo mail mới"/>

            <!-- Close -->
            <TextView
                android:id="@+id/btnClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="✕"
                android:textSize="14sp"
                android:gravity="center"
                android:textColor="#999999"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Đóng"/>
        </LinearLayout>

        <!-- Top divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"/>

        <!-- ── Section tabs ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:background="#F5F5F5">

            <TextView
                android:id="@+id/tabAccounts"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="👤 Tài khoản"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:gravity="center"
                android:background="#1565C0"/>

            <TextView
                android:id="@+id/tabMailList"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📧 Xác thực"
                android:textColor="#1565C0"
                android:textSize="11sp"
                android:gravity="center"
                android:background="@android:color/transparent"/>

            <TextView
                android:id="@+id/tabPanelTabs"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🗂 Tab"
                android:textColor="#1565C0"
                android:textSize="11sp"
                android:gravity="center"
                android:background="@android:color/transparent"/>
        </LinearLayout>

        <!-- Section tab bottom divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"/>

        <!-- ── Content area ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- ── SECTION 0: Accounts ── -->
            <LinearLayout
                android:id="@+id/accountsContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/accountList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                        <TextView
                            android:id="@+id/tvAccountsEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chưa có tài khoản\nĐăng nhập Replit để lưu"
                            android:textColor="#999999"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:paddingTop="24dp"
                            android:visibility="gone"/>
                    </LinearLayout>
                </ScrollView>
            </LinearLayout>

            <!-- ── SECTION 1: Verify / Inbox ── -->
            <LinearLayout
                android:id="@+id/verifyContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Mail status bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="8dp"
                    android:background="#F8F8F8">

                    <TextView
                        android:id="@+id/tvMailStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Đang khởi tạo..."
                        android:textColor="#555555"
                        android:textSize="10.5sp"
                        android:singleLine="true"
                        android:ellipsize="end"/>

                    <ProgressBar
                        android:id="@+id/pbMail"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:indeterminateTint="#1565C0"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- Mail list + verify WebView stacked -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <ScrollView
                        android:id="@+id/mailListScroll"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:clipToPadding="false">

                        <LinearLayout
                            android:id="@+id/mailList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>
                    </ScrollView>

                    <!-- Verify WebView -->
                    <WebView
                        android:id="@+id/verifyWebView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"/>
                </FrameLayout>
            </LinearLayout>

            <!-- ── SECTION 2: Tabs ── -->
            <LinearLayout
                android:id="@+id/tabsContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- New tab button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="#F0F4FF">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Các tab đang mở"
                        android:textColor="#1565C0"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/btnPanelNewTab"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="＋ Tab mới"
                        android:textColor="#1565C0"
                        android:textSize="11sp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>
                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/panelTabList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </ScrollView>
            </LinearLayout>

        </FrameLayout>

        <!-- Bottom status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#F5F5F5"
            android:paddingStart="10dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvBottomStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#888888"
                android:textSize="9.5sp"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
