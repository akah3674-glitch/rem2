<?xml version="1.0" encoding="utf-8"?>
  <androidx.constraintlayout.widget.ConstraintLayout
      xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="#F3F4F6">

      <!-- ══ HEADER (top) ══ -->
      <LinearLayout
          android:id="@+id/header"
          android:layout_width="0dp"
          android:layout_height="56dp"
          android:background="#1D4ED8"
          android:gravity="center_vertical"
          android:orientation="horizontal"
          android:paddingStart="16dp"
          android:paddingEnd="8dp"
          android:elevation="4dp"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintEnd_toEndOf="parent">

          <TextView
              android:id="@+id/tvTitle"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="⚡ Rem2 Browser"
              android:textColor="#FFFFFF"
              android:textSize="18sp"
              android:textStyle="bold" />

          <ImageButton
              android:id="@+id/btnToggleLog"
              android:layout_width="44dp"
              android:layout_height="44dp"
              android:background="?attr/selectableItemBackgroundBorderless"
              android:src="@drawable/ic_paste"
              android:tint="#FFFFFF"
              android:contentDescription="Toggle panel" />

          <ImageButton
              android:id="@+id/btnClearLog"
              android:layout_width="44dp"
              android:layout_height="44dp"
              android:background="?attr/selectableItemBackgroundBorderless"
              android:src="@drawable/ic_trash"
              android:tint="#FFFFFF"
              android:contentDescription="Clear log" />

      </LinearLayout>

      <!-- ══ PROGRESS BAR (below header) ══ -->
      <ProgressBar
          android:id="@+id/progressBar"
          style="?android:attr/progressBarStyleHorizontal"
          android:layout_width="0dp"
          android:layout_height="3dp"
          android:visibility="gone"
          android:progressTint="#60A5FA"
          android:progressBackgroundTint="#1D4ED8"
          app:layout_constraintTop_toBottomOf="@id/header"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintEnd_toEndOf="parent" />

      <!-- ══ MAIN WEBVIEW fills between header and bottom panel ══ -->
      <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
          android:id="@+id/swipeRefresh"
          android:layout_width="0dp"
          android:layout_height="0dp"
          app:layout_constraintTop_toBottomOf="@id/progressBar"
          app:layout_constraintBottom_toTopOf="@id/logPanel"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintEnd_toEndOf="parent">

          <WebView
              android:id="@+id/webView"
              android:layout_width="match_parent"
              android:layout_height="match_parent" />

      </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

      <!-- ══ LOG + VERIFY PANEL (BOTTOM, collapsible) ══ -->
      <LinearLayout
          android:id="@+id/logPanel"
          android:layout_width="0dp"
          android:layout_height="220dp"
          android:orientation="vertical"
          android:visibility="gone"
          android:background="#FFFFFF"
          android:elevation="6dp"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintEnd_toEndOf="parent">

          <!-- Tab row: Log | Xác thực -->
          <LinearLayout
              android:id="@+id/panelTabRow"
              android:layout_width="match_parent"
              android:layout_height="36dp"
              android:orientation="horizontal"
              android:background="#F3F4F6"
              android:gravity="center_vertical">

              <TextView
                  android:id="@+id/tabLog"
                  android:layout_width="0dp"
                  android:layout_height="match_parent"
                  android:layout_weight="1"
                  android:text="📋 Log"
                  android:gravity="center"
                  android:textSize="13sp"
                  android:textColor="#1D4ED8"
                  android:textStyle="bold"
                  android:background="#FFFFFF" />

              <TextView
                  android:id="@+id/tabVerify"
                  android:layout_width="0dp"
                  android:layout_height="match_parent"
                  android:layout_weight="1"
                  android:text="🌐 Xác thực"
                  android:gravity="center"
                  android:textSize="13sp"
                  android:textColor="#6B7280"
                  android:background="#F3F4F6" />

          </LinearLayout>

          <!-- Log area -->
          <ScrollView
              android:id="@+id/logScroll"
              android:layout_width="match_parent"
              android:layout_height="0dp"
              android:layout_weight="1"
              android:padding="8dp"
              android:fillViewport="true">

              <TextView
                  android:id="@+id/tvLog"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:fontFamily="monospace"
                  android:textSize="11sp"
                  android:textColor="#111827"
                  android:lineSpacingExtra="2dp"
                android:textIsSelectable="true" />
          </ScrollView>

          <!-- Verify mini WebView (same panel, tab-switched) -->
          <WebView
              android:id="@+id/verifyWebView"
              android:layout_width="match_parent"
              android:layout_height="0dp"
              android:layout_weight="1"
              android:visibility="gone" />

      </LinearLayout>

  </androidx.constraintlayout.widget.ConstraintLayout>