<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:background="@color/bg_dark">

      <!-- ── Blue header (như screenshot: title + 2 icon) ──────────────── -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="50dp"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:background="@color/accent_blue"
          android:paddingStart="14dp"
          android:paddingEnd="8dp"
          android:elevation="4dp">

          <TextView
              android:id="@+id/tvTitle"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="⚡ Rem2 Browser"
              android:textSize="16sp"
              android:textStyle="bold"
              android:textColor="#FFFFFF" />

          <!-- Toggle log panel (nút dán / clipboard) -->
          <TextView
              android:id="@+id/btnToggleLog"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:text="📋"
              android:textSize="18sp"
              android:gravity="center"
              android:textColor="#FFFFFF"
              android:padding="6dp" />

          <!-- Clear log (nút thùng rác) -->
          <TextView
              android:id="@+id/btnClearLog"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:text="🗑"
              android:textSize="18sp"
              android:gravity="center"
              android:textColor="#FFFFFF"
              android:padding="6dp" />
      </LinearLayout>

      <!-- ── Log panel (GONE mặc định, bật/tắt bằng btnToggleLog) ─────── -->
      <LinearLayout
          android:id="@+id/logPanel"
          android:layout_width="match_parent"
          android:layout_height="140dp"
          android:orientation="vertical"
          android:background="@color/bg_surface"
          android:visibility="gone"
          android:elevation="2dp">

          <ScrollView
              android:id="@+id/logScroll"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:padding="10dp"
              android:scrollbars="vertical">

              <TextView
                  android:id="@+id/tvLog"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:textSize="11sp"
                  android:textColor="@color/text_primary"
                  android:fontFamily="monospace"
                  android:lineSpacingExtra="3dp"
                  android:text="" />
          </ScrollView>
      </LinearLayout>

      <!-- ── Progress bar ──────────────────────────────────────────────── -->
      <ProgressBar
          android:id="@+id/progressBar"
          style="?android:attr/progressBarStyleHorizontal"
          android:layout_width="match_parent"
          android:layout_height="3dp"
          android:progressTint="@color/accent_blue"
          android:visibility="gone" />

      <!-- ── WebView (chiếm hết phần còn lại) ──────────────────────────── -->
      <FrameLayout
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1">

          <WebView
              android:id="@+id/webView"
              android:layout_width="match_parent"
              android:layout_height="match_parent" />

          <!-- Overlay xác thực email (dùng khi cần) -->
          <LinearLayout
              android:id="@+id/verifyOverlay"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:visibility="gone">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="40dp"
                  android:orientation="horizontal"
                  android:background="@color/accent_blue"
                  android:gravity="center_vertical"
                  android:paddingStart="12dp"
                  android:paddingEnd="8dp">

                  <TextView
                      android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1"
                      android:text="📧 Xác thực email"
                      android:textColor="#FFFFFF"
                      android:textSize="13sp"
                      android:textStyle="bold" />

                  <TextView
                      android:id="@+id/btnCloseVerify"
                      android:layout_width="34dp"
                      android:layout_height="34dp"
                      android:text="✕"
                      android:textColor="#FFFFFF"
                      android:textSize="14sp"
                      android:gravity="center"
                      android:padding="4dp" />
              </LinearLayout>

              <WebView
                  android:id="@+id/verifyWebView"
                  android:layout_width="match_parent"
                  android:layout_height="match_parent" />
          </LinearLayout>
      </FrameLayout>
  </LinearLayout>