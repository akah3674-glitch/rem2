<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="◀"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:padding="6dp" />
            <TextView
                android:id="@+id/btnForward"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="▶"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:padding="6dp" />
            <TextView
                android:id="@+id/btnRefresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="⟳"
                android:textSize="16sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:padding="6dp" />
            <EditText
                android:id="@+id/etUrl"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/search_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="12sp"
                android:textColor="#111827"
                android:hint="Tìm kiếm hoặc nhập URL..."
                android:textColorHint="#9CA3AF"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:inputType="textUri" />
            <TextView
                android:id="@+id/btnDesktop"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🖥"
                android:textSize="14sp"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:padding="6dp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="#2563EB"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:background="#F9FAFB"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/tabChipsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp" />
            </HorizontalScrollView>
            <TextView
                android:id="@+id/btnAddTab"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:text="+"
                android:textSize="16sp"
                android:textColor="#2563EB"
                android:gravity="center"
                android:background="@drawable/card_bg" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <FrameLayout
                android:id="@+id/webContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:id="@+id/verifyOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:orientation="horizontal"
                    android:background="#1D4ED8"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📧 Xác thực email"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/btnCloseVerify"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="✕"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:padding="4dp" />
                </LinearLayout>
                <WebView
                    android:id="@+id/verifyWebView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/fabMail"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:elevation="10dp">
        <TextView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="📧"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/fab_bg"
            android:elevation="10dp" />
        <TextView
            android:id="@+id/tvMailBadge"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="top|end"
            android:text=""
            android:textSize="8sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/dot_green"
            android:visibility="gone" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/mailPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginTop="80dp"
            android:background="@drawable/panel_bg"
            android:elevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1D4ED8"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">
                <TextView
                    android:id="@+id/btnPanelSearch"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🔍"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="4dp" />
                <TextView
                    android:id="@+id/tvPanelTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rem2 Browser"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="6dp" />
                <EditText
                    android:id="@+id/etPanelSearch"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:visibility="gone"
                    android:background="@drawable/search_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textSize="12sp"
                    android:textColor="#111827"
                    android:hint="Tìm kiếm..."
                    android:textColorHint="#9CA3AF"
                    android:singleLine="true"
                    android:imeOptions="actionGo"
                    android:inputType="text" />
                <TextView
                    android:id="@+id/btnNewMail"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:padding="4dp" />
                <TextView
                    android:id="@+id/btnPanelClose"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="✕"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="#EFF6FF">
                <TextView
                    android:id="@+id/tabPanelAccounts"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="👤 Tài khoản"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:textColor="#2563EB" />
                <TextView
                    android:id="@+id/tabPanelMail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="📧 Mail"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:textColor="#6B7280" />
                <TextView
                    android:id="@+id/tabPanelTabs"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="🗂 Tab"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:textColor="#6B7280" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/panelAccounts"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvAccountsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chưa có tài khoản nào
(Nhấn + để tạo mail.tm mới)"
                        android:textColor="#9CA3AF"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone" />
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <LinearLayout
                            android:id="@+id/accountList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingTop="6dp"
                            android:paddingBottom="12dp" />
                    </ScrollView>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panelMail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/card_bg"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvMailEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chưa có tài khoản"
                                android:textColor="#1D4ED8"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:singleLine="true" />
                            <TextView
                                android:id="@+id/tvMailStatus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="❌ Chưa có mail"
                                android:textColor="#6B7280"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📬 Hộp thư tự động theo dõi và mở link xác thực Replit
Nhấn + để tạo email mới"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:gravity="center" />
                </LinearLayout>

                <ScrollView
                    android:id="@+id/panelTabsView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">
                    <LinearLayout
                        android:id="@+id/panelTabList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="6dp"
                        android:paddingBottom="12dp" />
                </ScrollView>

            </FrameLayout>

        </LinearLayout>
    </FrameLayout>

</FrameLayout>