<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout
      xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:background="@color/bg_primary">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:background="@color/accent_blue"
          android:paddingStart="16dp"
          android:paddingEnd="16dp"
          android:paddingTop="14dp"
          android:paddingBottom="0dp">

          <TextView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:text="GoLike OPS"
              android:textColor="#FFFFFF"
              android:textSize="20sp"
              android:textStyle="bold"/>

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:layout_marginTop="10dp">

              <TextView
                  android:id="@+id/tabAccount"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:gravity="center"
                  android:text="👤 Tài khoản"
                  android:textSize="12sp"
                  android:textStyle="bold"
                  android:textColor="#FFFFFF"
                  android:paddingTop="8dp"
                  android:paddingBottom="8dp"
                  android:background="@color/accent_blue" />

              <TextView
                  android:id="@+id/tabCardHistory"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:gravity="center"
                  android:text="💳 Đổi thẻ"
                  android:textSize="12sp"
                  android:textStyle="bold"
                  android:textColor="#AACCFF"
                  android:paddingTop="8dp"
                  android:paddingBottom="8dp"
                  android:background="@color/accent_blue" />

              <!-- Tab 3: Mở Rem2 Browser (trình duyệt WebView độc lập) -->
              <TextView
                  android:id="@+id/tabBrowser"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:gravity="center"
                  android:text="🌐 Browser"
                  android:textSize="12sp"
                  android:textStyle="bold"
                  android:textColor="#AACCFF"
                  android:paddingTop="8dp"
                  android:paddingBottom="8dp"
                  android:background="@color/accent_blue" />

          </LinearLayout>
      </LinearLayout>

      <!-- TAB 1: Tài khoản -->
      <LinearLayout
          android:id="@+id/tab1Content"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:orientation="vertical">

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:padding="12dp"
              android:gravity="center_vertical">

              <com.google.android.material.button.MaterialButton
                  android:id="@+id/btnAdd"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:text="🔑 Dang nhap"
                  android:textSize="14sp"
                  android:padding="14dp"
                  android:backgroundTint="@color/accent_blue"
                  android:layout_marginEnd="8dp"/>

              <com.google.android.material.button.MaterialButton
                  android:id="@+id/btnImport"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:text="📂 Nhap file"
                  android:textSize="14sp"
                  android:padding="14dp"
                  android:backgroundTint="@color/accent_green"/>
          </LinearLayout>

          <TextView
              android:id="@+id/tvEmpty"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:padding="24dp"
              android:gravity="center"
              android:text="Chưa có tài khoản nào.&#10;Nhấn Đăng nhập để thêm."
              android:textSize="14sp"
              android:textColor="@color/text_muted"
              android:visibility="gone"/>

          <ScrollView
              android:layout_width="match_parent"
              android:layout_height="0dp"
              android:layout_weight="1">
              <LinearLayout
                  android:id="@+id/llAccounts"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:padding="12dp" />
          </ScrollView>
      </LinearLayout>

      <!-- TAB 2: Đổi thẻ cào -->
      <LinearLayout
          android:id="@+id/tab2Content"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:orientation="vertical"
          android:visibility="gone">

          <!-- Card chip (hiển thị file đã chọn) -->
          <LinearLayout
              android:id="@+id/llCardChip"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:padding="10dp"
              android:gravity="center_vertical"
              android:visibility="gone">

              <TextView
                  android:id="@+id/tvCardChipLabel"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:textSize="13sp"
                  android:textColor="@color/text_primary"
                  android:textStyle="bold"/>

              <com.google.android.material.button.MaterialButton
                  android:id="@+id/btnCardChipRemove"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="✕"
                  android:textSize="12sp"
                  android:padding="8dp"
                  android:backgroundTint="@color/accent_red"
                  android:layout_marginStart="8dp"/>
          </LinearLayout>

          <!-- Pick file bar -->
          <LinearLayout
              android:id="@+id/llCardPickBar"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:padding="12dp"
              android:gravity="center_vertical">

              <com.google.android.material.button.MaterialButton
                  android:id="@+id/btnPickCardFile"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:text="📁 Chon file the_cao"
                  android:textSize="14sp"
                  android:padding="14dp"
                  android:backgroundTint="@color/accent_blue"
                  android:layout_marginEnd="8dp"/>

              <com.google.android.material.button.MaterialButton
                  android:id="@+id/btnLoadSaved"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:text="📂 File hom nay"
                  android:textSize="14sp"
                  android:padding="14dp"
                  android:backgroundTint="@color/accent_green"/>
          </LinearLayout>

          <TextView
              android:id="@+id/tvCardEmpty"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:padding="24dp"
              android:gravity="center"
              android:text="Chon file the_cao_...txt de xem the theo nhom.&#10;Nhan File hom nay de tai file da rut hom nay."
              android:textSize="13sp"
              android:textColor="@color/text_muted"
              android:lineSpacingExtra="4dp" />

          <ScrollView
              android:layout_width="match_parent"
              android:layout_height="0dp"
              android:layout_weight="1">
              <LinearLayout
                  android:id="@+id/llCardGroups"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:padding="12dp" />
          </ScrollView>
      </LinearLayout>

  </LinearLayout>
